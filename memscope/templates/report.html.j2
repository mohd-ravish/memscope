<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MemScope — Memory Profile Report</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --surface2: #21262d;
    --border: #30363d;
    --text: #e6edf3;
    --muted: #8b949e;
    --teal: #39d0d8;
    --blue: #58a6ff;
    --purple: #bc8cff;
    --red: #f85149;
    --amber: #d29922;
    --green: #3fb950;
    --red-bg: rgba(248,81,73,0.12);
    --amber-bg: rgba(210,153,34,0.12);
    --green-bg: rgba(63,185,80,0.12);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size: 14px; line-height: 1.6; }
  a { color: var(--blue); }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px 60px; }

  /* Header */
  .header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 20px 24px; display: flex; align-items: center; gap: 16px; }
  .header h1 { font-size: 20px; font-weight: 700; letter-spacing: -0.5px; }
  .header .badge { background: var(--teal); color: #000; font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 12px; }
  .header .meta { margin-left: auto; color: var(--muted); font-size: 12px; }

  /* Banner */
  .banner { border-radius: 10px; padding: 18px 24px; margin: 28px 0; display: flex; gap: 32px; align-items: center; flex-wrap: wrap; border: 1px solid; }
  .banner.high { background: var(--red-bg); border-color: var(--red); }
  .banner.medium { background: var(--amber-bg); border-color: var(--amber); }
  .banner.low { background: var(--amber-bg); border-color: var(--amber); }
  .banner.none { background: var(--green-bg); border-color: var(--green); }
  .banner-stat { text-align: center; }
  .banner-stat .label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.8px; color: var(--muted); }
  .banner-stat .value { font-size: 22px; font-weight: 700; margin-top: 2px; }
  .banner-stat .value.red { color: var(--red); }
  .banner-stat .value.amber { color: var(--amber); }
  .banner-stat .value.green { color: var(--green); }
  .banner-divider { width: 1px; background: var(--border); height: 48px; }

  /* Cards / Sections */
  .section { margin-top: 32px; }
  .section-title { font-size: 16px; font-weight: 600; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 20px 24px; }

  /* Chart */
  .chart-wrap { position: relative; height: 300px; }

  /* Diagnosis */
  .diagnosis-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .diag-block { background: var(--surface2); border-radius: 8px; padding: 16px; }
  .diag-block .diag-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.8px; color: var(--muted); margin-bottom: 6px; }
  .diag-block .diag-value { font-size: 15px; font-weight: 600; }
  .diag-block pre { white-space: pre-wrap; font-size: 13px; font-family: 'JetBrains Mono','Fira Code',monospace; color: var(--text); margin-top: 4px; }
  .pattern-badge { display: inline-block; padding: 3px 10px; border-radius: 6px; font-size: 12px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; }
  .pattern-badge.linear_leak { background: var(--red-bg); color: var(--red); border: 1px solid var(--red); }
  .pattern-badge.periodic_accumulation { background: var(--amber-bg); color: var(--amber); border: 1px solid var(--amber); }
  .pattern-badge.over_allocation { background: var(--amber-bg); color: var(--amber); border: 1px solid var(--amber); }
  .pattern-badge.healthy { background: var(--green-bg); color: var(--green); border: 1px solid var(--green); }
  .pattern-badge.insufficient_data { background: var(--surface2); color: var(--muted); border: 1px solid var(--border); }

  /* Table */
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { text-align: left; padding: 8px 12px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.6px; color: var(--muted); border-bottom: 1px solid var(--border); }
  td { padding: 8px 12px; border-bottom: 1px solid var(--border); }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--surface2); }
  .mono { font-family: 'JetBrains Mono','Fira Code',monospace; font-size: 12px; }
  .pill { display: inline-block; padding: 2px 8px; border-radius: 4px; background: var(--surface2); font-size: 12px; }

  /* Layer chart */
  .layer-chart-wrap { height: 320px; position: relative; }

  /* Collapsible raw data */
  details { border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
  summary { padding: 14px 20px; cursor: pointer; font-weight: 600; background: var(--surface); user-select: none; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  summary::after { content: '▼'; font-size: 12px; color: var(--muted); }
  details[open] summary::after { content: '▲'; }
  .raw-table-wrap { max-height: 360px; overflow-y: auto; }
  .download-btn { margin: 12px 20px; display: inline-block; padding: 6px 16px; background: var(--surface2); border: 1px solid var(--border); border-radius: 6px; cursor: pointer; font-size: 13px; color: var(--text); text-decoration: none; }
  .download-btn:hover { background: var(--surface); border-color: var(--blue); }

  .empty-state { text-align: center; padding: 40px; color: var(--muted); }
  @media (max-width: 640px) { .diagnosis-grid { grid-template-columns: 1fr; } .banner { gap: 16px; } }
</style>
</head>
<body>

<div class="header">
  <span class="badge">MemScope</span>
  <h1>Memory Profile Report</h1>
  <span class="meta">{{ generated_at }}</span>
</div>

<div class="container">

  {# ── Summary Banner ── #}
  {% set sev = analysis.severity %}
  <div class="banner {{ sev }}">
    <div class="banner-stat">
      <div class="label">Pattern</div>
      <div class="value {{ 'red' if sev == 'high' else 'amber' if sev in ('medium','low') else 'green' }}">
        {{ analysis.pattern.replace('_',' ').upper() }}
      </div>
    </div>
    <div class="banner-divider"></div>
    <div class="banner-stat">
      <div class="label">Growth Rate</div>
      <div class="value {{ 'red' if analysis.growth_mb_per_step > 1 else 'green' }}">
        {% if analysis.growth_mb_per_step > 0 %}+{% endif %}{{ analysis.growth_mb_per_step }} MB/step
      </div>
    </div>
    <div class="banner-divider"></div>
    <div class="banner-stat">
      <div class="label">OOM Prediction</div>
      <div class="value {{ 'red' if analysis.oom_predicted_at_step else 'green' }}">
        {% if analysis.oom_predicted_at_step %}step {{ analysis.oom_predicted_at_step }}{% else %}N/A{% endif %}
      </div>
    </div>
    <div class="banner-divider"></div>
    <div class="banner-stat">
      <div class="label">Severity</div>
      <div class="value {{ 'red' if sev == 'high' else 'amber' if sev in ('medium','low') else 'green' }}">
        {{ sev.upper() }}
      </div>
    </div>
    <div class="banner-divider"></div>
    <div class="banner-stat">
      <div class="label">Samples</div>
      <div class="value" style="color:var(--text)">{{ total_samples }}</div>
    </div>
    <div class="banner-divider"></div>
    <div class="banner-stat">
      <div class="label">Peak GPU</div>
      <div class="value" style="color:var(--text)">{{ peak_allocated }} MB</div>
    </div>
  </div>

  {# ── Memory Timeline ── #}
  <div class="section">
    <div class="section-title">Memory Timeline</div>
    <div class="card">
      <div class="chart-wrap">
        <canvas id="memoryChart"></canvas>
      </div>
    </div>
  </div>

  {# ── Leak Diagnosis ── #}
  <div class="section">
    <div class="section-title">Leak Diagnosis</div>
    <div class="card">
      <div class="diagnosis-grid">
        <div class="diag-block">
          <div class="diag-label">Detected Pattern</div>
          <div class="diag-value" style="margin-top:8px">
            <span class="pattern-badge {{ analysis.pattern }}">{{ analysis.pattern.replace('_',' ') }}</span>
          </div>
        </div>
        <div class="diag-block">
          <div class="diag-label">Growth Rate</div>
          <div class="diag-value">
            {% if analysis.growth_mb_per_step > 0 %}+{% endif %}{{ analysis.growth_mb_per_step }} MB / step
          </div>
        </div>
        <div class="diag-block" style="grid-column: 1/-1">
          <div class="diag-label">Analysis</div>
          <pre>{{ analysis.message }}</pre>
        </div>
        <div class="diag-block" style="grid-column: 1/-1">
          <div class="diag-label">Recommendation</div>
          <pre>{{ analysis.recommendation }}</pre>
        </div>
      </div>
    </div>
  </div>

  {# ── Top Tensor Allocation Sites ── #}
  <div class="section">
    <div class="section-title">Top Tensor Allocation Sites <span style="color:var(--muted);font-weight:400;font-size:13px">(from CUDA snapshot)</span></div>
    <div class="card" style="padding:0">
      {% if top_tensors %}
      <table>
        <thead>
          <tr><th>#</th><th>Size</th><th>File</th><th>Line</th><th>Function</th></tr>
        </thead>
        <tbody>
          {% for t in top_tensors %}
          <tr>
            <td style="color:var(--muted)">{{ loop.index }}</td>
            <td><strong>{{ t.size_mb }} MB</strong></td>
            <td class="mono">{{ t.file.split('/')[-1].split('\\')[-1] }}</td>
            <td class="mono pill">{{ t.line }}</td>
            <td class="mono" style="color:var(--blue)">{{ t.function }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <div class="empty-state">
        No CUDA snapshot available — GPU not detected or CUDA snapshot not captured.<br>
        Run on a CUDA-enabled machine to see per-tensor allocation sites with stack traces.
      </div>
      {% endif %}
    </div>
  </div>

  {# ── Per-Layer Memory Breakdown ── #}
  <div class="section">
    <div class="section-title">Per-Layer Memory Breakdown <span style="color:var(--muted);font-weight:400;font-size:13px">(average output tensor size)</span></div>
    <div class="card">
      {% if layer_labels != '[]' %}
      <div class="layer-chart-wrap">
        <canvas id="layerChart"></canvas>
      </div>
      {% else %}
      <div class="empty-state">
        No layer data — call <code>prof.track_model(model)</code> or pass <code>model=model</code> to <code>MemoryProfiler()</code>.
      </div>
      {% endif %}
    </div>
  </div>

  {# ── Raw Samples ── #}
  <div class="section">
    <details>
      <summary>Raw Samples Table <span style="color:var(--muted);font-weight:400;font-size:12px">— {{ total_samples }} rows</span></summary>
      <div style="padding: 12px 20px 4px">
        <a class="download-btn" id="downloadBtn" href="#" download="memscope_samples.csv">Download CSV</a>
      </div>
      <div class="raw-table-wrap">
        <table>
          <thead>
            <tr><th>Step</th><th>Timestamp</th><th>Allocated (MB)</th><th>Reserved (MB)</th><th>CPU RAM (MB)</th></tr>
          </thead>
          <tbody>
            {% for s in samples %}
            <tr>
              <td>{{ s.step }}</td>
              <td class="mono">{{ "%.3f"|format(s.timestamp) }}</td>
              <td>{{ s.allocated_mb }}</td>
              <td>{{ s.reserved_mb }}</td>
              <td>{{ s.cpu_mb }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </details>
  </div>

</div>{# /container #}

<script>
const steps = {{ chart_steps }};
const allocated = {{ chart_allocated }};
const reserved = {{ chart_reserved }};
const cpuRam = {{ chart_cpu }};
const layerLabels = {{ layer_labels }};
const layerValues = {{ layer_values }};

// ── Memory Timeline Chart ──
const memCtx = document.getElementById('memoryChart').getContext('2d');
new Chart(memCtx, {
  type: 'line',
  data: {
    labels: steps,
    datasets: [
      {
        label: 'Allocated GPU (MB)',
        data: allocated,
        borderColor: '#39d0d8',
        backgroundColor: 'rgba(57,208,216,0.08)',
        borderWidth: 2,
        pointRadius: allocated.length > 200 ? 0 : 2,
        tension: 0.3,
        fill: true,
      },
      {
        label: 'Reserved GPU (MB)',
        data: reserved,
        borderColor: '#8b949e',
        backgroundColor: 'transparent',
        borderWidth: 1.5,
        borderDash: [6, 3],
        pointRadius: 0,
        tension: 0.3,
      },
      {
        label: 'CPU RAM (MB)',
        data: cpuRam,
        borderColor: '#bc8cff',
        backgroundColor: 'transparent',
        borderWidth: 1.5,
        borderDash: [2, 3],
        pointRadius: 0,
        tension: 0.3,
      },
    ],
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    interaction: { mode: 'index', intersect: false },
    plugins: {
      legend: { labels: { color: '#8b949e', boxWidth: 20 } },
      tooltip: {
        backgroundColor: '#161b22',
        borderColor: '#30363d',
        borderWidth: 1,
        titleColor: '#e6edf3',
        bodyColor: '#8b949e',
        callbacks: {
          label: ctx => ` ${ctx.dataset.label}: ${ctx.parsed.y.toFixed(1)} MB`,
        },
      },
    },
    scales: {
      x: {
        ticks: { color: '#8b949e', maxTicksLimit: 12 },
        grid: { color: 'rgba(48,54,61,0.5)' },
        title: { display: true, text: 'Training Step', color: '#8b949e' },
      },
      y: {
        ticks: { color: '#8b949e', callback: v => v + ' MB' },
        grid: { color: 'rgba(48,54,61,0.5)' },
        title: { display: true, text: 'Memory (MB)', color: '#8b949e' },
      },
    },
  },
});

// ── Per-Layer Horizontal Bar Chart ──
if (layerLabels.length > 0) {
  const layerCtx = document.getElementById('layerChart').getContext('2d');
  new Chart(layerCtx, {
    type: 'bar',
    data: {
      labels: layerLabels,
      datasets: [{
        label: 'Avg Output Size (MB)',
        data: layerValues,
        backgroundColor: 'rgba(57,208,216,0.7)',
        borderColor: '#39d0d8',
        borderWidth: 1,
        borderRadius: 4,
      }],
    },
    options: {
      indexAxis: 'y',
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#161b22',
          borderColor: '#30363d',
          borderWidth: 1,
          bodyColor: '#8b949e',
          callbacks: { label: ctx => ` ${ctx.parsed.x.toFixed(3)} MB` },
        },
      },
      scales: {
        x: {
          ticks: { color: '#8b949e', callback: v => v + ' MB' },
          grid: { color: 'rgba(48,54,61,0.5)' },
        },
        y: {
          ticks: { color: '#e6edf3', font: { family: "'JetBrains Mono','Fira Code',monospace", size: 11 } },
          grid: { display: false },
        },
      },
    },
  });
}

// ── CSV Download ──
(function buildCsvDownload() {
  const header = 'step,timestamp,allocated_mb,reserved_mb,cpu_mb\n';
  const rows = steps.map((s, i) =>
    `${s},${(allocated[i] || 0).toFixed(2)},${(reserved[i] || 0).toFixed(2)},${(cpuRam[i] || 0).toFixed(2)}`
  ).join('\n');
  const blob = new Blob([header + rows], { type: 'text/csv' });
  const url = URL.createObjectURL(blob);
  const btn = document.getElementById('downloadBtn');
  if (btn) btn.href = url;
})();
</script>
</body>
</html>
